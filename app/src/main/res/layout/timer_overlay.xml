<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/timer_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <!-- Main timer text: "HH:MM:SS.ss" with minus sign when negative -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/timer_minus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="−"
            android:textColor="#A0000000"
            android:textSize="36sp"
            android:visibility="gone"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/timer_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:textColor="#A0000000"
            android:textSize="36sp"
            tools:text="0:00.00" />

        <TextView
            android:id="@+id/timer_delta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:textColor="#A0006000"
            android:textSize="16sp"
            android:visibility="gone"
            tools:text="−1.24"
            tools:visibility="visible" />
    </LinearLayout>

    <!-- Current split name -->
    <TextView
        android:id="@+id/timer_split"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:maxWidth="180dp"
        android:maxLines="1"
        android:textColor="#A0000000"
        android:textSize="14sp"
        android:visibility="gone"
        tools:text="Wall Jump"
        tools:visibility="visible" />

</LinearLayout>
